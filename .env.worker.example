# Local Claude Worker 配置文件
# 复制此文件为 .env.worker 并填入实际值
# .env.worker 已加入 .gitignore，不会被提交

# 服务器地址 (你部署 super-assistant 的服务器)
SUPER_ASSISTANT_SERVER=http://你的服务器地址:8000

# Worker Token (必须和服务器 .env 中的 LOCAL_WORKER_TOKEN 一致)
LOCAL_WORKER_TOKEN=请生成强随机token例如 openssl rand -hex 32

# LLM Wiki 根目录 (你本机的外脑 Wiki 目录)
# Windows 示例: D:\my-llm-wiki
# Mac/Linux 示例: /Users/yourname/my-llm-wiki
LLM_WIKI_ROOT=D:\my-llm-wiki

# Claude Code 命令
# Windows (cc-switch / cmd wrapper):
#   cmd.exe /d /s /c claude
# Mac/Linux:
#   claude
CLAUDE_COMMAND=cmd.exe /d /s /c claude

# Claude 调用超时 (秒)
CLAUDE_TIMEOUT_SECONDS=900

# Worker 轮询间隔 (秒)
WORKER_POLL_INTERVAL_SECONDS=3
